  "no_player_found_message": "{red}[CS2FaceitLevels] No player found matching {default}{SEARCH}",
  "multiple_players_found_message": "{red}[CS2FaceitLevels] Multiple players found: {default}{PLAYERS}",
  "player_name_color": "{RED}",
  "elo_label_color": "{LIGHTPURPLE}",
  "no_faceit_text": "N/A",
  "no_faceit_color": "{GREY}",
  "level_1_elo_color": "{GREY}",
  "level_2_elo_color": "{GREEN}",
  "level_3_elo_color": "{GREEN}",
  "level_4_elo_color": "{YELLOW}",
  "level_5_elo_color": "{YELLOW}",
